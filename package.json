{
  "name": "lazyvec",
  "version": "0.1.1",
  "description": "A terminal UI for browsing vector databases.",
  "license": "MIT",
  "author": "Armen Gabrielyan",
  "repository": {
    "type": "git",
    "url": "https://github.com/armgabrielyan/lazyvec"
  },
  "keywords": [
    "vector-database",
    "qdrant",
    "pinecone",
    "chroma",
    "tui",
    "terminal"
  ],
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "lazyvec": "./src/index.tsx"
  },
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "start": "bun run src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build src/index.tsx --outdir=dist --target=bun"
  },
  "dependencies": {
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
    "@pinecone-database/pinecone": "^7.2.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "chromadb": "^3.4.3",
    "react": "^19.2.4",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "typescript": "^5"
  }
}
